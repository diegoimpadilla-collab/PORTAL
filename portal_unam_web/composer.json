{
    "name": "portal-unam/portal-egresados",
    "description": "Portal de Egresados UNAM Moquegua",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": ">=8.1",
        "codeigniter4/framework": "^4.5"
    },
    "require-dev": {
        "fakerphp/faker": "^1.9"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        },
        "exclude-from-classmap": [
            "**/Database/Migrations/**"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\Support\\": "tests/support"
        }
    },
    "scripts": {
        "post-update-cmd": [
            "CodeIgniter4\\ComposerScripts::postUpdate"
        ]
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    }
}
